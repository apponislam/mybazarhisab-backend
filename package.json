{
    "name": "mybazarhisab-backend",
    "version": "1.0.0",
    "description": "Backend API for Bazar Hisab - shared household budget and grocery expense tracking system.",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "lint": "npx eslint src",
        "lint:fix": "npx eslint src --fix",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [
        "bazar-hisab",
        "expense-tracker",
        "grocery-tracker",
        "household-budget",
        "shared-expense",
        "mongodb",
        "express",
        "typescript",
        "rest-api"
    ],
    "author": "Appon Islam",
    "license": "MIT",
    "type": "commonjs",
    "dependencies": {
        "@sparticuz/chromium-min": "^149.0.0",
        "axios": "^1.13.6",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "http-status": "^2.1.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.2.1",
        "morgan": "^1.11.0",
        "nodemailer": "^9.0.3",
        "puppeteer": "^25.3.0",
        "puppeteer-core": "^25.3.0",
        "socket.io": "^4.8.3",
        "ts-node-dev": "^2.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.2.3",
        "@types/nodemailer": "^7.0.10",
        "typescript": "^5.9.3"
    }
}
